    \u0E23\u0E31\u0E07\u0E2A\u0E35\u0E17\u0E30\u0E25\u0E38\u0E1C\u0E48\u0E32\u0E19\u0E42\u0E14\u0E22\u0E44\u0E21\u0E48\u0E17\u0E34\u0E49\u0E07\u0E2A\u0E32\u0E23\u0E15\u0E01\u0E04\u0E49\u0E32\u0E07
    \u2014 \u0E2D\u0E32\u0E2B\u0E32\u0E23\u0E08\u0E36\u0E07\u0E1B\u0E25\u0E2D\u0E14\u0E20\u0E31\u0E22\u0E15\u0E48\u0E2D\u0E01\u0E32\u0E23\u0E1A\u0E23\u0E34\u0E42\u0E20\u0E04\n\n\U0001F353
